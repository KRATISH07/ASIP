# ======================
# Application
# ======================
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ======================
# Database (PostgreSQL)
# ======================
POSTGRES_USER=asip_user
POSTGRES_PASSWORD=asip_password
POSTGRES_DB=asip_db
DATABASE_URL=postgresql+asyncpg://asip_user:asip_password@localhost:5432/asip_db

# ======================
# ChromaDB (Vector Store)
# ======================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=asip_knowledge_base

# ======================
# LLM Configuration
# ======================
# Options: openai | google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini (alternative)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# ======================
# Embedding Model
# ======================
EMBEDDING_MODEL=text-embedding-3-small

# ======================
# Notifications (Optional)
# ======================
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@asip.ai
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ======================
# Frontend
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8000
